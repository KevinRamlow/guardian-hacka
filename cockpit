#!/bin/bash
# Quick launcher for Agent Cockpit
# Usage: ./cockpit [view|serve|path]

set -euo pipefail

WORKSPACE="/root/.openclaw/workspace"
MODE="${1:-view}"

case "$MODE" in
    view|v)
        # Text view in terminal
        "$WORKSPACE/agent-cockpit.sh"
        ;;
    serve|s)
        # Generate and serve
        "$WORKSPACE/agent-cockpit-simple.sh"
        echo ""
        echo "🌐 Starting web server..."
        cd /tmp && python3 -m http.server 8765
        ;;
    path|p)
        # Just generate and show path
        "$WORKSPACE/agent-cockpit-simple.sh" | grep "^/tmp"
        ;;
    html|h)
        # Generate HTML with auto-populated data
        "$WORKSPACE/agent-cockpit.sh" --html
        ;;
    help|--help|-h)
        cat <<EOF
Agent Cockpit - Subagent Monitor

Usage: ./cockpit [command]

Commands:
  view, v     Show text dashboard in terminal (default)
  serve, s    Generate HTML and start web server
  path, p     Generate HTML and print path
  html, h     Generate auto-populated HTML
  help        Show this help

Examples:
  ./cockpit              # Quick terminal view
  ./cockpit serve        # Open in browser
  ./cockpit path         # Get file path only
EOF
        ;;
    *)
        echo "Unknown command: $MODE"
        echo "Run './cockpit help' for usage"
        exit 1
        ;;
esac
