#!/bin/bash
# Quick status check for Anton Auto-Loop

echo "=== Anton Two-Level Auto-Loop Status ==="
echo ""

# Launchd status - Guardian Loop
echo "📅 Guardian Loop (every 4 hours):"
STATUS=$(launchctl list | grep "anton.auto-loop" || echo "NOT LOADED")
if [[ "$STATUS" == "NOT LOADED" ]]; then
  echo "  ❌ Guardian loop not running"
else
  echo "  ✅ Guardian loop active"
fi

# Launchd status - Meta Loop
echo ""
echo "🔧 Meta Loop (every 24 hours):"
META_STATUS=$(launchctl list | grep "anton.meta-loop" || echo "NOT LOADED")
if [[ "$META_STATUS" == "NOT LOADED" ]]; then
  echo "  ❌ Meta loop not running"
else
  echo "  ✅ Meta loop active"
fi

echo ""

# Guardian state
if [[ -f ~/.openclaw/workspace/.anton-auto-state.json ]]; then
  echo "📊 Guardian State:"
  cat ~/.openclaw/workspace/.anton-auto-state.json | jq -r '
    "  Baseline: \(.baseline_accuracy)%\n  Cycle: \(.cycle)\n  Last run: \(.last_run // "never")\n  Last improvement: \(.last_improvement // "none") (\(.last_delta // "0")pp)"
  '
else
  echo "📊 Guardian State: No runs yet"
fi

echo ""

# Meta state
if [[ -f ~/.openclaw/workspace/.anton-meta-state.json ]]; then
  echo "🔧 Meta State:"
  cat ~/.openclaw/workspace/.anton-meta-state.json | jq -r '
    "  Agent success rate: \(.agent_success_rate)%\n  Avg task time: \(.avg_task_time)min\n  Cycle: \(.cycle)\n  Last run: \(.last_run // "never")"
  '
else
  echo "🔧 Meta State: No runs yet"
fi

echo ""

# Objectives
echo "🎯 Target:"
TARGET=$(grep -A1 "target:" ~/.openclaw/workspace/OBJECTIVES.md | grep -o '[0-9]*' | head -1)
echo "  $TARGET% accuracy"

echo ""

# Recent agents
echo "🤖 Active Agents:"
bash ~/.openclaw/workspace/scripts/agent-registry.sh list | head -5 || echo "  None"

echo ""

# Logs
echo "📝 Recent Log:"
tail -5 ~/.openclaw/workspace/logs/anton-auto-loop.log 2>/dev/null || echo "  No logs yet"

echo ""
echo "Full docs: cat ~/.openclaw/workspace/ANTON-AUTO-LOOP.md"
