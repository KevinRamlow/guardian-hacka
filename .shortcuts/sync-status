#!/bin/bash
# Quick sync status check

echo "=== Replicant Sync Status ==="
echo ""

# Check launchd
SYNC_JOB=$(launchctl list | grep "anton.sync-replicants" || echo "NOT LOADED")
if [[ "$SYNC_JOB" == "NOT LOADED" ]]; then
  echo "📅 Schedule: ❌ Not running"
else
  echo "📅 Schedule: ✅ Active (every 4 hours)"
fi

echo ""

# Last sync
LAST_SYNC=$(ls -t ~/.openclaw/workspace/logs/sync-replicants-*.log 2>/dev/null | head -1)
if [[ -n "$LAST_SYNC" ]]; then
  SYNC_TIME=$(stat -f "%Sm" -t "%Y-%m-%d %H:%M:%S" "$LAST_SYNC" 2>/dev/null || stat -c "%y" "$LAST_SYNC" 2>/dev/null)
  echo "📊 Last Sync: $SYNC_TIME"
  echo ""
  echo "Recent activity:"
  tail -5 "$LAST_SYNC" | sed 's/^/  /'
else
  echo "📊 Last Sync: Never"
fi

echo ""

# Check Son connection
echo "🔗 Son of Anton Connection:"
if ssh -o ConnectTimeout=5 caio@89.167.23.2 "echo 'Connected'" 2>/dev/null; then
  echo "  ✅ Reachable"
  
  # Check if Son has latest OBJECTIVES
  SON_OBJ_TIME=$(ssh caio@89.167.23.2 "stat -c %Y /home/caio/workspace/OBJECTIVES.md 2>/dev/null" 2>/dev/null || echo "0")
  ANTON_OBJ_TIME=$(stat -f "%m" ~/.openclaw/workspace/OBJECTIVES.md 2>/dev/null || stat -c "%Y" ~/.openclaw/workspace/OBJECTIVES.md 2>/dev/null)
  
  DELTA=$((ANTON_OBJ_TIME - SON_OBJ_TIME))
  if [[ $DELTA -gt 300 ]]; then
    echo "  ⚠️  Son's OBJECTIVES.md is $((DELTA/60)) min out of date"
  else
    echo "  ✅ Files in sync"
  fi
else
  echo "  ❌ Unreachable (check SSH or network)"
fi

echo ""
echo "Run sync: bash ~/.openclaw/workspace/scripts/sync-replicants.sh"
echo "Preview: bash ~/.openclaw/workspace/scripts/sync-replicants.sh --dry-run"
