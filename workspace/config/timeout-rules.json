{
  "rules": {
    "guardian_eval": {
      "timeout_min": 60,
      "keywords": ["guardian", "eval", "evaluation", "content moderation", "run_eval", "121 cases", "moderation eval", "guardian eval"]
    },
    "code_task": {
      "timeout_min": 30,
      "keywords": ["feat", "feature", "fix", "bug", "implement", "refactor", "code", "function", "class", "endpoint", "migration", "schema"]
    },
    "analysis": {
      "timeout_min": 20,
      "keywords": ["analysis", "analyze", "investigate", "report", "check", "review", "audit", "summarize", "compare", "diagnose"]
    },
    "image_gen": {
      "timeout_min": 5,
      "keywords": ["image", "generate image", "nano banana", "dall-e", "stable diffusion", "midjourney"]
    },
    "default": {
      "timeout_min": 25
    }
  },
  "_comment": "Rules are checked in order: guardian_eval > code_task > analysis > image_gen > default. First keyword match wins."
}
