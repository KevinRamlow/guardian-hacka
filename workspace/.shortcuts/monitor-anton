#!/bin/bash
# monitor-anton - Full status check of Anton (Mac)

set -euo pipefail

echo "=== Anton Status Monitor ==="
echo ""

echo "📊 Auto-Loop Status:"
ssh anton-mac "bash ~/.openclaw/workspace/.shortcuts/auto-loop-status" 2>/dev/null || echo "❌ Cannot reach Mac"

echo ""
echo "🤖 Active Agents:"
ssh anton-mac "bash ~/.openclaw/workspace/scripts/agent-registry.sh list" 2>/dev/null || echo "❌ Cannot fetch registry"

echo ""
echo "💾 State Files:"
ssh anton-mac "cat ~/.openclaw/workspace/.anton-auto-state.json 2>/dev/null | jq -r '.last_run_time, .success_rate_24h, .daily_budget_remaining'" 2>/dev/null || echo "❌ Cannot read state"
