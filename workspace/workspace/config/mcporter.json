{
  "mcpServers": {
    "mysql-creator-ads": {
      "command": "npx",
      "args": ["-y", "@benborla29/mcp-server-mysql"],
      "env": {
        "MYSQL_HOST": "${CREATOR_ADS_DB_HOST}",
        "MYSQL_PORT": "${CREATOR_ADS_DB_PORT}",
        "MYSQL_USER": "${CREATOR_ADS_DB_USER}",
        "MYSQL_PASS": "${CREATOR_ADS_DB_PASSWORD}",
        "MYSQL_DB": "${CREATOR_ADS_DB_NAME}",
        "ALLOW_INSERT_OPERATION": "false",
        "ALLOW_UPDATE_OPERATION": "false",
        "ALLOW_DELETE_OPERATION": "false"
      }
    },
    "mysql-catalyst": {
      "command": "npx",
      "args": ["-y", "@benborla29/mcp-server-mysql"],
      "env": {
        "MYSQL_HOST": "${DB_CATALYST_HOST}",
        "MYSQL_PORT": "${DB_CATALYST_PORT}",
        "MYSQL_USER": "${DB_CATALYST_USER}",
        "MYSQL_PASS": "${DB_CATALYST_PASSWORD}",
        "MYSQL_DB": "${DB_CATALYST_NAME}",
        "ALLOW_INSERT_OPERATION": "false",
        "ALLOW_UPDATE_OPERATION": "false",
        "ALLOW_DELETE_OPERATION": "false"
      }
    },
    "notion": {
      "command": "npx",
      "args": ["-y", "@notionhq/notion-mcp-server"],
      "env": {
        "NOTION_TOKEN": "${NOTION_API_KEY}"
      }
    },
    "metabase": {
      "command": "npx",
      "args": ["-y", "metabase-ai-assistant"],
      "env": {
        "METABASE_URL": "https://metabase.brandlovers.ai",
        "METABASE_API_KEY": "${METABASE_API_KEY}",
        "MB_METADATA_ENABLED": "true"
      }
    },
    "langfuse": {
      "command": "uvx",
      "args": ["--python", "3.11", "langfuse-mcp"],
      "env": {
        "LANGFUSE_PUBLIC_KEY": "${LANGFUSE_PUBLIC_KEY}",
        "LANGFUSE_SECRET_KEY": "${LANGFUSE_SECRET_KEY}",
        "LANGFUSE_HOST": "https://us.cloud.langfuse.com"
      }
    },
    "nano-banana": {
      "command": "nano-banana-pro-mcp",
      "env": {
        "GEMINI_API_KEY": "${GEMINI_API_KEY}"
      }
    }
  }
}
