# ══════════════════════════════════════════════════════
# Anton OpenClaw — Environment Variables
# ══════════════════════════════════════════════════════
# Copy to .env and fill in values. NEVER commit .env.
# In GKE, these come from K8s Secrets (sm-k8s).
# ══════════════════════════════════════════════════════

# ── LLM Provider ──
ANTHROPIC_API_KEY=sk-ant-...

# ── OpenClaw Gateway ──
OPENCLAW_GATEWAY_TOKEN=          # openssl rand -hex 24

# ── Slack ──
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_USER_TOKEN=xoxp-...        # optional, read-only user token

# ── Git Identity (optional, defaults shown) ──
GIT_AUTHOR_NAME=Anton [bot]
GIT_AUTHOR_EMAIL=anton-bot@fonsecabc.dev

# ── Integrations ──
GITHUB_TOKEN=ghp_...
LINEAR_API_KEY=lin_api_...
GEMINI_API_KEY=AIza...
NOTION_API_KEY=ntn_...
METABASE_API_KEY=mb_...

# ── Observability ──
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com

# ── Database (Cloud SQL via proxy or direct) ──
DB_MAESTRO_HOST=127.0.0.1
DB_MAESTRO_PORT=3306
DB_MAESTRO_NAME=
DB_MAESTRO_USER=
DB_MAESTRO_PASSWORD=

# ── GCP (set by Workload Identity in GKE, manual locally) ──
GOOGLE_CLOUD_PROJECT=brandlovers-prod
GOOGLE_CLOUD_LOCATION=us-east1

# ── Google Keyring ──
GOG_KEYRING_PASSWORD=

# ── Gateway Config ──
GATEWAY_PORT=18789
GATEWAY_BIND=loopback            # loopback (local) or lan (Docker/GKE)
NODE_ENV=production
