# OpenClaw internal runtime dirs (these don't exist at repo root,
# but listed explicitly to avoid any accidental inclusion if created)
# NOTE: do NOT add workspace/skills/ or workspace/memory/ here — they are
# source code and must be in the image.
tasks/
agents/
browser/
canvas/
completions/
delivery-queue/
devices/
identity/
logs/
media/
subagents/
cron/
# Sub-agent workspaces (built at image build + container startup)
workspace-*/

# Secrets
.env
.env.*
!.env.example
credentials/

# Git
.git/
.gitignore

# Docs / CI (not needed in container)
.github/
infra/

# Heavy workspace subdirs (cloned repos, not needed in image)
workspace/billy-workspace/
workspace/clawdbots/
workspace/guardian-agents-api-real/
workspace/campaign-manager-api/
workspace/.archive/
workspace/**/.archive/
workspace/node_modules/
workspace/**/__pycache__/
workspace/presentations/
workspace/dashboard/node_modules/
workspace/.git/

# Workspace runtime state
workspace/.env*
workspace/metrics/
workspace/tasks/
workspace/logs/

# Large/generated files
*.bak*
*.png
*.jpg
*.mp4
*.zip
.DS_Store
