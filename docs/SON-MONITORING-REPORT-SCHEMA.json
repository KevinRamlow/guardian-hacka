{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Son of Anton Monitoring Report",
  "description": "Structured monitoring report from Son of Anton to Anton (not a memory file)",
  "type": "object",
  "required": ["timestamp", "observer", "observations"],
  "properties": {
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "When this report was generated"
    },
    "observer": {
      "type": "string",
      "const": "son-of-anton",
      "description": "Who generated this report"
    },
    "observations": {
      "type": "object",
      "description": "Objective observations (not memories)",
      "properties": {
        "guardian_loop": {
          "type": "object",
          "properties": {
            "baseline_accuracy": {"type": "number"},
            "cycle_count": {"type": "integer"},
            "last_delta": {"type": "number"},
            "status": {"enum": ["healthy", "stagnant", "offline"]},
            "last_run": {"type": "string", "format": "date-time"}
          }
        },
        "meta_loop": {
          "type": "object",
          "properties": {
            "agent_success_rate": {"type": "number"},
            "avg_task_time": {"type": "number"},
            "cycle_count": {"type": "integer"},
            "status": {"enum": ["healthy", "degraded", "offline"]}
          }
        },
        "infrastructure": {
          "type": "object",
          "properties": {
            "launchd_jobs_active": {"type": "integer"},
            "active_agents": {"type": "integer"},
            "queued_tasks": {"type": "integer"}
          }
        }
      }
    },
    "alerts": {
      "type": "array",
      "description": "Issues detected",
      "items": {
        "type": "object",
        "properties": {
          "severity": {"enum": ["info", "warning", "critical"]},
          "category": {"type": "string"},
          "message": {"type": "string"},
          "detected_at": {"type": "string", "format": "date-time"}
        }
      }
    },
    "actions_taken": {
      "type": "array",
      "description": "What Son did in response",
      "items": {
        "type": "object",
        "properties": {
          "action": {"type": "string"},
          "result": {"enum": ["success", "failed", "pending"]},
          "timestamp": {"type": "string", "format": "date-time"}
        }
      }
    },
    "recommendations": {
      "type": "array",
      "description": "Suggestions for Anton/Caio",
      "items": {"type": "string"}
    }
  }
}
