#!/bin/bash
# anton-auto-loop.sh - Autonomous self-training loop (macOS compatible)
# Runs every 4 hours via launchd

set -e

WORKSPACE="$HOME/.openclaw/workspace"
REPO_DIR="$WORKSPACE/guardian-agents-api-real"
STATE_FILE="$WORKSPACE/.anton-auto-state.json"
LOG_FILE="$WORKSPACE/logs/anton-auto-loop.log"

mkdir -p "$WORKSPACE/logs"
exec >> "$LOG_FILE" 2>&1

echo ""
echo "=========================================="
echo "Anton Auto-Loop - $(date)"
echo "=========================================="

# Read current baseline
if [[ -f "$STATE_FILE" ]]; then
  BASELINE=$(jq -r '.baseline_accuracy // "79.3"' "$STATE_FILE")
  CYCLE=$(jq -r '.cycle // 0' "$STATE_FILE")
else
  BASELINE="79.3"
  CYCLE=0
fi

CYCLE=$((CYCLE + 1))

echo "Cycle: $CYCLE"
echo "Baseline: $BASELINE%"

# Check if objectives file exists
if [[ ! -f "$WORKSPACE/OBJECTIVES.md" ]]; then
  echo "ERROR: OBJECTIVES.md not found. Exiting."
  exit 1
fi

# Extract target from OBJECTIVES.md (macOS compatible)
TARGET=$(grep -A1 "target:" "$WORKSPACE/OBJECTIVES.md" | grep -Eo '[0-9]+' | head -1)
echo "Target: $TARGET%"

# Check if target reached (using awk for float comparison)
if awk -v b="$BASELINE" -v t="$TARGET" 'BEGIN {exit !(b >= t)}'; then
  echo "🎯 TARGET REACHED! Baseline $BASELINE% >= Target $TARGET%"
  echo "Stopping auto-loop. Edit OBJECTIVES.md to set new target."
  exit 0
fi

# Generate hypotheses (simple version - will be enhanced with LLM later)
echo ""
echo "=== Generating Hypotheses ==="

# Read priority areas from OBJECTIVES.md
PRIORITY_AREA=$(grep -A3 "Priority Areas" "$WORKSPACE/OBJECTIVES.md" | grep "###" | head -1 | sed 's/###//g' | xargs)
echo "Focus area: $PRIORITY_AREA"

# Define hypothesis templates
HYPOTHESES=(
  "prompt-refinement:Refine severity scale in phase 2 agent prompts"
  "archetype-tuning:Adjust archetype injection thresholds"
  "routing-optimization:Improve phase 1→2 routing logic"
  "judge-calibration:Tune borderline judge agent sensitivity"
  "error-pattern-update:Add new anti-error patterns from recent failures"
)

# Pick 3 random hypotheses for this cycle (macOS compatible - no shuf)
SELECTED_HYPOTHESES=()
INDICES=$(jot -r 3 0 $((${#HYPOTHESES[@]} - 1)))
for idx in $INDICES; do
  SELECTED_HYPOTHESES+=("${HYPOTHESES[$idx]}")
done

echo "Selected hypotheses:"
for i in "${!SELECTED_HYPOTHESES[@]}"; do
  echo "  $((i+1)). ${SELECTED_HYPOTHESES[$i]}"
done

# Spawn agents for each hypothesis (fast mode)
echo ""
echo "=== Spawning Agents (Fast Mode) ==="

RESULTS=()
for HYPOTHESIS in "${SELECTED_HYPOTHESES[@]}"; do
  LABEL=$(echo "$HYPOTHESIS" | cut -d: -f1)
  DESC=$(echo "$HYPOTHESIS" | cut -d: -f2)
  
  echo "Testing: $LABEL - $DESC"
  
  # Create task file
  TASK_FILE="/tmp/anton-auto-task-$LABEL-$CYCLE.md"
  MIN_TARGET=$(awk -v b="$BASELINE" 'BEGIN {printf "%.1f", b + 1.0}')
  cat > "$TASK_FILE" << EOF
# Auto-Loop Task: $LABEL (Cycle $CYCLE)

## Objective
$DESC

## Current Baseline
$BASELINE% accuracy (guidelines_combined dataset)

## Target
Improve by +1pp minimum (validation required)

## Instructions

1. **Analyze current state:**
   - Review recent eval runs in guardian-agents-api-real/evals/.runs/
   - Identify failing cases in the priority area

2. **Implement hypothesis:**
   - Make targeted code changes based on hypothesis
   - Focus on: $LABEL

3. **Fast validation:**
   - Run: bash scripts/fast-eval.sh
   - Target: >$MIN_TARGET% on fast dataset

4. **Report format:**
   - Changes made: [list files modified]
   - Fast eval accuracy: [X.X%]
   - Delta: [+X.Xpp]
   - Recommendation: [proceed to full eval / abandon]

## Success Criteria
- Fast eval shows +1pp improvement
- No obvious regressions in code review

## Time Budget
15 minutes
EOF

  # Spawn agent (non-blocking)
  AGENT_ID="AUTO-LOOP-$CYCLE-$LABEL"
  
  bash "$WORKSPACE/scripts/spawn-agent.sh" \
    --task "$AGENT_ID" \
    --label "anton-auto:$LABEL" \
    --timeout 15 \
    --model "sonnet" \
    --file "$TASK_FILE" &
  
  AGENT_PID=$!
  echo "  Spawned: $AGENT_ID (PID $AGENT_PID)"
  
  RESULTS+=("$AGENT_ID:$AGENT_PID:$LABEL")
  
  # Stagger spawns
  sleep 5
done

echo ""
echo "Agents spawned. Waiting for completion..."
echo "Check status: bash scripts/agent-peek.sh"

# Wait for all agents (max 20 minutes)
sleep 1200

echo ""
echo "=== Collecting Results ==="

BEST_ACCURACY="$BASELINE"
BEST_LABEL=""
BEST_CHANGES=""

for RESULT in "${RESULTS[@]}"; do
  AGENT_ID=$(echo "$RESULT" | cut -d: -f1)
  LABEL=$(echo "$RESULT" | cut -d: -f3)
  
  OUTPUT_LOG="$HOME/.openclaw/tasks/agent-logs/${AGENT_ID}-output.log"
  
  if [[ -f "$OUTPUT_LOG" ]]; then
    # Extract accuracy from output (macOS compatible)
    ACCURACY=$(grep -Eo 'Fast eval accuracy: [0-9.]+' "$OUTPUT_LOG" | grep -Eo '[0-9.]+' | head -1)
    
    if [[ -n "$ACCURACY" ]]; then
      echo "$LABEL: $ACCURACY%"
      
      # Check if best (using awk)
      if awk -v a="$ACCURACY" -v b="$BEST_ACCURACY" 'BEGIN {exit !(a > b)}'; then
        BEST_ACCURACY="$ACCURACY"
        BEST_LABEL="$LABEL"
        BEST_CHANGES=$(grep -A10 "Changes made:" "$OUTPUT_LOG" | head -11)
      fi
    else
      echo "$LABEL: No result"
    fi
  else
    echo "$LABEL: Agent failed (no output)"
  fi
done

# Check if we improved
DELTA=$(awk -v best="$BEST_ACCURACY" -v base="$BASELINE" 'BEGIN {printf "%.1f", best - base}')

echo ""
echo "=== Cycle Results ==="
echo "Best hypothesis: $BEST_LABEL"
echo "Best accuracy: $BEST_ACCURACY%"
echo "Delta: +${DELTA}pp"

if awk -v d="$DELTA" 'BEGIN {exit !(d >= 1.0)}'; then
  echo ""
  echo "✅ IMPROVEMENT FOUND! Running full validation..."
  
  # Run full eval to confirm
  cd "$REPO_DIR"
  bash "$WORKSPACE/scripts/run-guardian-eval.sh" guidelines_combined_dataset.jsonl 15 5
  
  # Wait for completion and check result
  sleep 2400  # 40 min
  
  LATEST_RUN=$(ls -td evals/.runs/content_moderation/run_* | head -1)
  FULL_ACCURACY=$(tail -1 "$LATEST_RUN/results.jsonl" 2>/dev/null | jq -r '.summary.accuracy' 2>/dev/null || echo "0")
  
  echo "Full validation: $FULL_ACCURACY%"
  
  MIN_FULL=$(awk -v b="$BASELINE" 'BEGIN {printf "%.1f", b + 1.0}')
  if awk -v f="$FULL_ACCURACY" -v m="$MIN_FULL" 'BEGIN {exit !(f >= m)}'; then
    echo ""
    echo "🎉 VALIDATED! Committing changes..."
    
    # Commit (changes already applied by agent)
    git add -A
    git commit -m "AUTO-LOOP: $BEST_LABEL (+${DELTA}pp validated)

Cycle: $CYCLE
Fast eval: $BEST_ACCURACY%
Full validation: $FULL_ACCURACY%
Baseline: $BASELINE% → $FULL_ACCURACY%

$BEST_CHANGES
"
    
    # Update state
    jq -n \
      --arg baseline "$FULL_ACCURACY" \
      --arg cycle "$CYCLE" \
      --arg label "$BEST_LABEL" \
      --arg delta "$DELTA" \
      '{baseline_accuracy: $baseline, cycle: ($cycle|tonumber), last_improvement: $label, last_delta: $delta, last_run: (now|todate)}' \
      > "$STATE_FILE"
    
    echo "State updated: $STATE_FILE"
    
    # Notify in Slack
    bash "$WORKSPACE/scripts/notify-slack.sh" "🚀 Anton Auto-Loop Cycle $CYCLE: +${DELTA}pp improvement validated! $BASELINE% → $FULL_ACCURACY% ($BEST_LABEL)"
  else
    echo "❌ Full validation failed. Not committing."
  fi
else
  echo ""
  echo "No significant improvement this cycle. Continue exploring..."
  
  # Update state (no baseline change)
  jq -n \
    --arg baseline "$BASELINE" \
    --arg cycle "$CYCLE" \
    '{baseline_accuracy: $baseline, cycle: ($cycle|tonumber), last_run: (now|todate)}' \
    > "$STATE_FILE"
fi

echo ""
echo "=== Syncing with Son of Anton ==="
bash "$WORKSPACE/scripts/sync-replicants.sh" --to-son || echo "Sync failed (Son may be offline)"

echo ""
echo "=========================================="
echo "Anton Auto-Loop Complete"
# macOS compatible date (4 hours ahead)
NEXT_RUN=$(date -v+4H)
echo "Next run: $NEXT_RUN"
echo "=========================================="
