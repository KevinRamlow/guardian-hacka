{
  "name": "zendesk",
  "version": "1.0.0",
  "description": "Zendesk ticket analytics for CS team workload, status, and response metrics",
  "emoji": "🎫",
  "author": "Anton",
  "created": "2026-03-06",
  "requires": {
    "env": [
      "ZENDESK_SUBDOMAIN",
      "ZENDESK_EMAIL",
      "ZENDESK_API_TOKEN"
    ]
  },
  "features": [
    "Ticket status tracking (open/pending/solved)",
    "CS team workload distribution",
    "Response time metrics by priority",
    "Tag and category analytics",
    "SLA compliance monitoring",
    "Mock mode for testing without credentials"
  ],
  "tags": ["zendesk", "customer-support", "analytics", "cs-team", "tickets"]
}
